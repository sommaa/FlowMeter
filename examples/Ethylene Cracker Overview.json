  "global_variables": [
    {
      "name": "Mass_Balance_Residual",
      "formula": "col['Feed_Naphtha_tph'] - col['Ethylene_Product_tph'] - col['Propylene_Product_tph'] - col['Fuel_Gas_tph'] - col['Pygas_tph']",
      "description": "Mass balance closure check (t/h). Should be near zero if the mass balance closes. Positive = unmeasured losses, negative = measurement overcount."
    },
    {
      "name": "Delta_CW_Temp",
      "formula": "col['CW_Return_Temp_degC'] - col['CW_Supply_Temp_degC']",
      "description": "Cooling water temperature rise across heat exchangers (\u00b0C)."
    },
    {
      "name": "CW_Heat_Duty_MW",
      "formula": "col['CW_Flow_m3h'] * 4.18 * col['Delta_CW_Temp'] / 3600",
      "description": "Total cooling water heat duty (MW). Uses \u0394T from global variable Delta_CW_Temp."
    },
    {
      "name": "Specific_Energy_GJ_per_t",
      "formula": "(col['Fuel_Gas_Consumed_tph'] * 47.0 + col['Power_MW'] * 3.6) / col['Ethylene_Product_tph']",
      "description": "Specific energy consumption per tonne of ethylene produced (GJ/t). Includes fuel gas (LHV=47 GJ/t) and electricity (3.6 GJ/MWh)."
    }
  ],
