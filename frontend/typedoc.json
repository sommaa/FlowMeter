{
  "entryPoints": ["src"],
  "entryPointStrategy": "expand",
  "out": "docs",
  "name": "FlowMeter Documentation",
  "includeVersion": true,
  "readme": "none",
  "plugin": [],
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeExternals": true,
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/node_modules/**"
  ],
  "categorizeByGroup": true,
  "categoryOrder": [
    "Components",
    "Hooks",
    "Services",
    "Store",
    "Types",
    "Utilities",
    "*"
  ],
  "sort": ["source-order"],
  "theme": "default",
  "navigationLinks": {
    "GitHub": "https://github.com/sommaa/flowmeter"
  },
  "sidebarLinks": {},
  "hideGenerator": false,
  "searchInComments": true,
  "cleanOutputDir": true
}
